@import "~/.cache/wal/colors-rofi.rasi"

configuration {
    click-to-exit: true;
    show-icons: false;
}

* {
    window-bg-color:       rgba(11, 18, 26, 0.75);
    selected-bg-color:     rgba(255, 255, 255, 0.15);
    unselected-bg-color:   transparent;
    selected-text-color:   rgba(255, 255, 255, 1);
    unselected-text-color: rgba(255, 255, 255, 0.85);
    font-family:      "Satoshi Variable 14";
}

window {
    width:            300px;
    height:           250px;
    border:           0px;
    border-radius:    12px;
    background-color: rgba(0, 0, 0, 0.3);
}


mainbox {
    background-color: transparent;
    children:         [ listview ];
}

listview {
    background-color: transparent;
    border:           0px;
    padding:          6px;
    spacing:          4px;
}

scrollbar {
    background-color: transparent;
    handle-color:     rgba(255, 255, 255, 0.2);
}

element {
    background-color: @unselected-bg-color;
    text-color:       @unselected-text-color;
    padding:          10px 14px;
    border-radius:    8px;
    horizontal-align: 0.5;
}

element selected {
    background-color: @selected-bg-color;
    text-color:       @selected-text-color;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    horizontal-align: 0.5;
    font: "Satoshi Variable 12";
}
